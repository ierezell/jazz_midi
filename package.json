{
	"name": "jazz_midi",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"packageManager": "pnpm@10.11.0",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"test": "vitest",
		"test:ui": "vitest --ui",
		"test:coverage": "vitest --coverage",
		"test:unit": "vitest run src/lib/tests",
		"test:integration": "vitest run tests",
		"test:e2e": "playwright test",
		"e2e:sequential": "node ./scripts/run-e2e-sequential.js",
		"test:all": "pnpm run lint && pnpm run check && pnpm run test:unit && pnpm run test:e2e",
		"test:ci": "pnpm run lint && pnpm run check && pnpm run test:unit",
		"upload:exercises": "tsx scripts/upload-exercises.ts"
	},
	"devDependencies": {
		"@eslint/compat": "2.0.5",
		"@eslint/js": "10.0.1",
		"@fontsource/fira-mono": "5.2.7",
		"@neoconfetti/svelte": "^2.0.0",
		"@playwright/test": "^1.59.1",
		"@skeletonlabs/skeleton": "^4.15.2",
		"@skeletonlabs/skeleton-svelte": "^4.15.2",
		"@sveltejs/adapter-auto": "7.0.1",
		"@sveltejs/kit": "2.57.1",
		"@sveltejs/vite-plugin-svelte": "7.0.0",
		"@testing-library/jest-dom": "6.9.1",
		"@testing-library/svelte": "^5.3.1",
		"@types/deep-eql": "^4.0.2",
		"@types/node": "25.6.0",
		"@types/webmidi": "^2.1.0",
		"@vitest/ui": "^4.1.4",
		"deep-eql": "^5.0.2",
		"dotenv": "^17.4.2",
		"eslint": "10.2.1",
		"eslint-config-prettier": "10.1.8",
		"eslint-plugin-svelte": "^3.17.0",
		"globals": "^17.5.0",
		"happy-dom": "^20.9.0",
		"jsdom": "^29.0.2",
		"opensheetmusicdisplay": "^1.9.7",
		"prettier": "3.8.3",
		"prettier-plugin-svelte": "^3.5.1",
		"svelte": "5.55.4",
		"svelte-check": "4.4.6",
		"tsx": "^4.22.3",
		"typescript": "6.0.3",
		"typescript-eslint": "8.58.2",
		"vite": "8.0.8",
		"vitest": "^4.1.4"
	},
	"dependencies": {
		"@spotify/basic-pitch": "^1.0.1",
		"@supabase/supabase-js": "^2.106.1",
		"@sveltejs/adapter-static": "3.0.10",
		"@tailwindcss/vite": "^4.2.2",
		"@vercel/analytics": "^2.0.1",
		"@vercel/speed-insights": "^2.0.0",
		"lucide-svelte": "^1.0.1",
		"opensheetmusicdisplay": "^1.9.7",
		"tailwindcss": "^4.1.16",
		"vexflow": "^5.0.0"
	}
}